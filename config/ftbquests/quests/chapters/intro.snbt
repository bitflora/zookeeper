	quests: [
		{
			description: [
				"The world is scarred. Lost."
				""
				"Years have passed since the loss of the ultimate zookeeper, but the wounds have not healed."
				""
				"It is up to you. You must bring back the ultimate zookeeper. And to do that, you will have to become the penultimate zookeeper."
				""
				"Travel the world. Gather its creatures. Learn their secrets. Gain their strength. Save the zookeeper, save the world."
				"Welcome!"
			]
			id: "542CDE05F61489C1"
			rewards: [{
				id: "1D8BDE43B188D3E8"
